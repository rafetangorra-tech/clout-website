---
import Layout from '../../../layouts/Layout.astro';
import { SITE } from '../../../data/site';
import { jsonLd } from '../../../data/schema';
import { BLOG_POSTS, BLOG_CATEGORIES, BLOG_ROOT, blogPostUrl } from '../../../data/blog';

const pageUrl = BLOG_ROOT;
const lastUpdatedIso = '2026-05-27';
const lastUpdatedDisplay = 'May 27, 2026';

const breadcrumbs = [
  { name: 'Home', url: SITE.url },
  { name: 'Resources', url: `${SITE.url}/resources/` },
  { name: 'Blog', url: pageUrl },
];

const categories = ['All', ...BLOG_CATEGORIES];

// Group posts by category for ordered display (Cliffco pattern — sectioned by category)
const grouped = BLOG_CATEGORIES.map((cat) => ({
  category: cat,
  posts: BLOG_POSTS.filter((p) => p.category === cat),
}));

// Blog schema — container that every BlogPosting links back to via isPartOf
const blogSchema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  '@id': `${pageUrl}#blog`,
  name: 'Clout Non-QM Blog',
  description:
    'Plain-language guides for mortgage brokers placing wholesale Non-QM files and real estate investors qualifying on cash flow, bank statements, 1099 income, or assets — covering DSCR, Bank Statement, 1099 Only, P&L Only, and Foreign National programs.',
  url: pageUrl,
  publisher: { '@id': `${SITE.url}#organization` },
  inLanguage: 'en-US',
  blogPost: BLOG_POSTS.map((p) => ({
    '@type': 'BlogPosting',
    '@id': `${blogPostUrl(p.slug)}#post`,
    headline: p.title,
    description: p.description,
    url: blogPostUrl(p.slug),
    datePublished: p.datePublished,
    dateModified: p.dateModified,
    articleSection: p.category,
    author: { '@id': `${SITE.url}#organization` },
    publisher: { '@id': `${SITE.url}#organization` },
  })),
};
---

<Layout
  title="Clout Non-QM Blog — Guides for Brokers and Real Estate Investors"
  description={`Plain-language Non-QM guides from Clout (NMLS #${SITE.nmlsId}) — DSCR underwriting, Bank Statement income, 1099 Only mortgages, Foreign National DSCR, and field guides for mortgage brokers placing wholesale Non-QM files. ${BLOG_POSTS.length} articles across ${BLOG_CATEGORIES.length} categories.`}
  canonical={pageUrl}
  breadcrumbs={breadcrumbs}
  extraSchema={[jsonLd(blogSchema)]}
>
  <section class="hero">
    <div class="container">
      <p class="eyebrow">Resources · Blog</p>
      <h1>Plain-language guides on Non-QM, written by people who close the files.</h1>
      <p class="answer-first lead">
        Whether you're a mortgage broker placing wholesale Non-QM files, a real estate
        investor qualifying on cash flow, or a self-employed borrower whose tax returns
        understate your income — these {BLOG_POSTS.length} articles answer the questions
        we hear most often at the Clout scenario desk.
      </p>
      <p class="reviewed-by">
        Reviewed by Clout Wholesale Operations · NMLS #{SITE.nmlsId} · Last updated <time datetime={lastUpdatedIso}>{lastUpdatedDisplay}</time>
      </p>
    </div>
  </section>

  <section class="filter-band">
    <div class="container">
      <div class="filter-pills" role="group" aria-label="Filter blog by topic">
        {categories.map((cat, i) => (
          <button
            class={`filter-pill ${i === 0 ? 'is-active' : ''}`}
            type="button"
            data-filter={cat === 'All' ? 'all' : cat}
          >
            {cat}
          </button>
        ))}
      </div>
    </div>
  </section>

  <section class="band">
    <div class="container">
      <div class="post-list">
        {grouped.map((group) => (
          <section class="cat-section" data-section={group.category}>
            <header class="cat-head">
              <h2>{group.category}</h2>
              <span class="cat-count">{group.posts.length} {group.posts.length === 1 ? 'article' : 'articles'}</span>
            </header>
            <div class="post-grid">
              {group.posts.map((p) => (
                <a
                  href={blogPostUrl(p.slug)}
                  class="post-card"
                  data-category={p.category}
                >
                  <p class="post-cat">{p.category}</p>
                  <h3>{p.title}</h3>
                  <p class="post-desc">{p.description}</p>
                  <div class="post-foot">
                    <time class="post-date" datetime={p.datePublished}>
                      {new Date(p.datePublished + 'T00:00:00Z').toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' })}
                    </time>
                    <span class="post-link">Read article →</span>
                  </div>
                </a>
              ))}
            </div>
          </section>
        ))}
      </div>

      <p id="no-results" class="no-results" hidden>
        No articles in this category yet — try "All" or call <a href={`tel:${SITE.phone}`}>{SITE.phoneDisplay}</a> for a scenario.
      </p>
    </div>
  </section>

  <section class="band band-compliance">
    <div class="container">
      <p class="compliance-row">
        Blog content is educational and does not constitute regulatory or legal advice,
        program guidelines, or a commitment to lend. {SITE.legalName} · NMLS
        <a href={SITE.nmlsUrl} target="_blank" rel="noopener">#{SITE.nmlsId}</a> ·
        Equal Housing Lender · Licensed in NY · NJ · PA · FL · CT · TX.
      </p>
    </div>
  </section>
</Layout>

<script>
  const pills = document.querySelectorAll<HTMLButtonElement>('.filter-pill');
  const sections = document.querySelectorAll<HTMLElement>('.cat-section');
  const cards = document.querySelectorAll<HTMLAnchorElement>('.post-card');
  const noResults = document.getElementById('no-results');

  pills.forEach((pill) => {
    pill.addEventListener('click', () => {
      pills.forEach((p) => p.classList.remove('is-active'));
      pill.classList.add('is-active');
      const filter = pill.dataset.filter ?? 'all';

      if (filter === 'all') {
        sections.forEach((s) => s.removeAttribute('hidden'));
        cards.forEach((c) => c.removeAttribute('hidden'));
        noResults?.setAttribute('hidden', '');
        return;
      }

      let visible = 0;
      sections.forEach((s) => {
        const matches = s.dataset.section === filter;
        if (matches) {
          s.removeAttribute('hidden');
          s.querySelectorAll('.post-card').forEach((c) => {
            c.removeAttribute('hidden');
            visible++;
          });
        } else {
          s.setAttribute('hidden', '');
        }
      });
      if (visible === 0) noResults?.removeAttribute('hidden');
      else noResults?.setAttribute('hidden', '');
    });
  });
</script>

<style>
  .container { max-width: 1180px; margin: 0 auto; padding: 0 1.5rem; }

  .hero {
    padding: 4.5rem 0 2.5rem;
    background:
      radial-gradient(900px 360px at 12% -10%, color-mix(in srgb, var(--color-brand-bright) 16%, transparent) 0%, transparent 60%),
      linear-gradient(180deg, var(--color-paper) 0%, var(--color-surface) 100%);
  }
  .eyebrow {
    font-size: var(--text-micro);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-brand-warmth);
    font-weight: 700;
    margin: 0 0 1rem;
  }
  .hero h1 {
    font-size: clamp(2rem, 4.5vw, 3rem);
    line-height: 1.1;
    margin: 0 0 1.25rem;
    max-width: 30ch;
    letter-spacing: -0.015em;
  }
  .hero .lead { max-width: 64ch; margin: 0 0 1.25rem; }
  .hero .reviewed-by { margin: 0; }

  /* Filter pills */
  .filter-band {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--color-paper);
    border-top: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
    box-shadow: 0 4px 16px -10px rgba(0, 65, 70, 0.10);
  }
  .filter-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    padding: 0.75rem 0;
  }
  .filter-pill {
    appearance: none;
    border: 1px solid var(--color-line);
    background: var(--color-paper);
    color: var(--color-ink-soft);
    padding: 0.5rem 0.875rem;
    font-size: var(--text-small);
    font-weight: 500;
    border-radius: 999px;
    cursor: pointer;
    transition: border-color 120ms ease, color 120ms ease, background 120ms ease;
    font-family: inherit;
  }
  .filter-pill:hover {
    border-color: var(--color-brand);
    color: var(--color-brand-deep);
  }
  .filter-pill.is-active {
    background: var(--color-brand-deep);
    color: var(--color-paper);
    border-color: var(--color-brand-deep);
  }

  .band { padding: 3rem 0 4rem; }

  /* Sectioned by category, like Cliffco */
  .post-list { display: grid; gap: 3rem; }
  .cat-section { scroll-margin-top: 5rem; }
  .cat-section[hidden] { display: none; }
  .cat-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin: 0 0 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid var(--color-line);
  }
  .cat-head h2 {
    font-size: clamp(1.375rem, 2.5vw, 1.75rem);
    margin: 0;
    color: var(--color-brand);
  }
  .cat-count {
    font-size: var(--text-meta);
    color: var(--color-mid);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .post-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .post-card {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    padding: 1.5rem;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    background: var(--color-paper);
    text-decoration: none;
    color: var(--color-ink);
    transition: border-color 120ms ease, transform 120ms ease, box-shadow 120ms ease;
  }
  .post-card:hover {
    border-color: var(--color-brand);
    transform: translateY(-2px);
    box-shadow: 0 16px 32px -16px rgba(1, 128, 118, 0.18);
  }
  .post-cat {
    font-size: var(--text-micro);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-brand-warmth);
    font-weight: 700;
    margin: 0;
  }
  .post-card h3 {
    font-size: 1.0625rem;
    line-height: 1.3;
    margin: 0;
    color: var(--color-ink);
  }
  .post-desc {
    font-size: var(--text-small);
    color: var(--color-ink-soft);
    line-height: 1.55;
    margin: 0;
    flex: 1;
  }
  .post-foot {
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid color-mix(in srgb, var(--color-line) 70%, transparent);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: var(--text-meta);
  }
  .post-date { color: var(--color-mid); }
  .post-link { color: var(--color-brand-deep); font-weight: 600; }
  .post-card[hidden] { display: none; }

  .no-results {
    text-align: center;
    color: var(--color-mid);
    font-size: var(--text-small);
    margin: 2rem 0;
  }

  .band-compliance { padding: 1rem 0 3.5rem; }
  .compliance-row { max-width: 96ch; }

  @media (max-width: 960px) { .post-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .post-grid { grid-template-columns: 1fr; } }
</style>
