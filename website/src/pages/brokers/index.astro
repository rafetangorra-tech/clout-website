---
import Layout from '../../layouts/Layout.astro';
import { SITE } from '../../data/site';

const pageUrl = `${SITE.url}/brokers/`;
const breadcrumbs = [
  { name: 'Home', url: SITE.url },
  { name: 'Brokers', url: pageUrl },
];
---

<Layout
  title="For Mortgage Brokers — Wholesale Non-QM Partner Channel"
  description="Place wholesale Non-QM files with Clout. Speed-of-close, transparent comp, broker-friendly underwriting. 10 Non-QM programs licensed in NY, NJ, PA, FL, CT, TX."
  canonical={pageUrl}
  breadcrumbs={breadcrumbs}
>
  <section class="header-band">
    <div class="container">
      <p class="eyebrow">For mortgage brokers</p>
      <h1>Place Non-QM files with a wholesale lender that closes.</h1>
      <p class="answer-first">
        Clout is the wholesale Non-QM channel for mortgage brokers across NY, NJ, PA,
        FL, CT, and TX. Ten programs, 15–25 day average close on DSCR and Bank
        Statement, transparent compensation, and account executives who pick up the
        phone. NMLS #{SITE.nmlsId}.
      </p>
      <div class="hero-cta">
        <a href="/tpo-connect/" class="cta-primary">Partner login</a>
        <a href="/contact/" class="cta-secondary">Become a partner</a>
      </div>
    </div>
  </section>

  <section class="band">
    <div class="container">
      <p class="stub-message">Full broker resource center — programs at a glance, turn-time data, rate sheets, partner SOPs, and AE bios — coming soon.</p>
    </div>
  </section>
</Layout>

<style>
  .container { max-width: 920px; margin: 0 auto; padding: 0 1.5rem; }
  .header-band { padding: 4rem 0 2rem; background: linear-gradient(180deg, transparent 0, var(--color-surface) 100%); }
  .eyebrow {
    font-size: var(--text-micro);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-brand-warmth);
    font-weight: 700;
    margin: 0 0 1rem;
  }
  h1 { font-size: clamp(2rem, 4.5vw, 3rem); margin: 0 0 1.25rem; max-width: 22ch; }
  .answer-first { max-width: 60ch; margin: 0 0 2rem; }
  .hero-cta { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .band { padding: 3rem 0; }
  .stub-message {
    color: var(--color-mid);
    border: 1px dashed var(--color-line);
    padding: 1.5rem;
    border-radius: var(--radius-lg);
    text-align: center;
  }
</style>
