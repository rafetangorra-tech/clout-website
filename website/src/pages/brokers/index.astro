---
import Layout from '../../layouts/Layout.astro';
import { SITE, PRODUCTS, STATES } from '../../data/site';
import { faqSchema, jsonLd } from '../../data/schema';

const pageUrl = `${SITE.url}/brokers/`;
const lastUpdatedIso = '2026-05-27';
const lastUpdatedDisplay = 'May 27, 2026';

const breadcrumbs = [
  { name: 'Home', url: SITE.url },
  { name: 'Brokers', url: pageUrl },
];

const tier1 = PRODUCTS.filter((p) => p.tier === 1);
const tier2 = PRODUCTS.filter((p) => p.tier === 2);
const tier3 = PRODUCTS.filter((p) => p.tier === 3);
const featuredProducts = [...tier1, ...tier2, ...tier3];

// Value props — quotable, specific, no superlatives
const valueProps = [
  {
    title: 'Speed of close',
    detail:
      'DSCR purchases run 15–20 days clear-to-close. Bank Statement and 1099 files run 18–25. Initial credit decision in 24–72 hours across nearly all programs.',
  },
  {
    title: 'Named AE access',
    detail:
      'Every partner broker gets a named account executive with a cell phone, an email, and a 4-business-hour internal response commitment on conditions. No 1-800 queue.',
  },
  {
    title: 'Broker-elected comp',
    detail:
      'LPC or BPC at the rate you have on file. Comp is disclosed on the lock, paid at funding, reconciled monthly. No file-by-file negotiation.',
  },
  {
    title: 'Program breadth',
    detail:
      '10 Non-QM programs — DSCR, Bank Statement, 1099, Foreign National, Asset Qualifier, plus five narrower programs. One submission point, one underwriting team.',
  },
  {
    title: 'Parent-Cliffco depth',
    detail:
      'Clout is a division of Cliffco Mortgage Bankers, founded 1989. Three decades of Non-QM and non-conforming origination experience behind every file.',
  },
  {
    title: 'Geographic focus',
    detail:
      'Licensed in six high-volume Non-QM states: NY, NJ, PA, FL, CT, TX. Deep market knowledge in NYC metro, Florida, Texas — not stretched thin.',
  },
];

// Published service standards — a concrete, citable commitment table
const serviceStandards = [
  ['Rate sheet refresh', 'Daily, by 9:30 AM ET'],
  ['Scenario desk response (clean, before 2 PM ET)', 'Same business day'],
  ['Initial credit decision', '24–72 hours'],
  ['Conditions response (internal)', '4 business hours'],
  ['Underwriter handoff visibility', 'Named underwriter on every file'],
  ['Lock confirmation turnaround', 'Same business day'],
  ['Comp reconciliation cycle', 'Monthly'],
  ['AE response — calls', 'Same business day'],
];

// What makes Clout different — honest, non-superlative
const differentiators = [
  {
    point: 'A division, not a startup.',
    detail:
      'Clout is the wholesale Non-QM channel of Cliffco Mortgage Bankers (NMLS #65328), founded 1989. The infrastructure, secondary marketing, and warehouse lines are not new — only the broker-facing brand is.',
  },
  {
    point: 'One underwriting team for all 10 programs.',
    detail:
      'Files do not bounce between three sub-shops by program. The same desk underwrites your DSCR, your Bank Statement, and your Foreign National — which means consistent decisions when you cross-sell a borrower.',
  },
  {
    point: 'Published service standards, not slogans.',
    detail:
      'Turn-time commitments, AE response windows, and scenario-desk SLAs are published on this site and inside TPO Connect. If we miss them, you can point at the page.',
  },
  {
    point: 'Six states, deeply.',
    detail:
      'Local AE coverage and program tuning is built around NY, NJ, PA, FL, CT, and TX — the states that drive the majority of Non-QM volume. We are not chasing 50-state coverage.',
  },
];

// Path to placement — abbreviated; the deep version lives on /tpo-connect/
const placementSteps = [
  {
    n: '01',
    title: 'Apply',
    body:
      'Email PowerUp@CLOUTwmb.com with your company NMLS, states, and expected volume — or call 844-477-3111. AE assigned within one business day.',
  },
  {
    n: '02',
    title: 'Onboard',
    body:
      'Submit your broker package (W-9, broker agreement, E&O cert, NMLS license, AML policy, principal resumes). 30-minute AE call walks you through TPO Connect. Approved in 5–7 business days.',
  },
  {
    n: '03',
    title: 'Submit',
    body:
      'Run a scenario through the desk, register in TPO Connect, submit eDocs. Most first files clear-to-close inside 25 days.',
  },
];

// Broker-channel FAQs — different scope than /tpo-connect/ (which is portal-specific)
const faqs = [
  {
    question: 'Why partner with Clout for wholesale Non-QM?',
    answer:
      'Clout is the wholesale Non-QM channel of Cliffco Mortgage Bankers (NMLS #65328), founded 1989. Partners get 10 Non-QM programs through a single submission point, named AE access with a 4-business-hour response commitment, broker-elected comp (LPC or BPC), and published service standards. Typical close is 15–25 days on DSCR and Bank Statement files across NY, NJ, PA, FL, CT, and TX.',
  },
  {
    question: 'What is wholesale Non-QM lending?',
    answer:
      'Wholesale Non-QM lending is the channel mortgage brokers use to place non-qualified mortgage loans with a wholesale lender on behalf of borrowers who do not fit conforming or government guidelines. Common Non-QM programs include DSCR (qualifies on rental cash flow), Bank Statement (qualifies on deposits), 1099 Only, Foreign National, and Asset Qualifier. The broker shops, prices, and packages the file; the wholesale lender (Clout) underwrites, funds, and services or sells the loan.',
  },
  {
    question: 'What Non-QM programs can brokers place with Clout?',
    answer:
      'Ten programs: DSCR, Bank Statement (12 or 24 month), 1099 Only, Foreign National, Asset Qualifier, Non-Agency Second Home, P&L Only, Lite Documentation, Written VOE Only, and Full Documentation Non-QM. Loan amounts $100,000 to $5,000,000. Minimum FICO 620 on standard programs, with exceptions on stronger compensating-factor files.',
  },
  {
    question: 'Does Clout offer agency (Fannie / Freddie / FHA / VA) products?',
    answer:
      'No. Clout is a Non-QM specialist channel. Brokers placing conforming and government loans should use other wholesale partners for those products. Parent company Cliffco Mortgage Bankers offers conforming and government products on the retail side, but the Clout wholesale channel is Non-QM only.',
  },
  {
    question: 'How does Clout compare to other wholesale Non-QM lenders?',
    answer:
      'Clout differentiates on four published items: (1) named AE with cell phone access and a 4-business-hour internal response commitment, (2) one underwriting team across all 10 programs so cross-sells stay consistent, (3) parent-Cliffco infrastructure dating to 1989 — not a Non-QM startup, (4) deep coverage in six high-Non-QM-volume states rather than thin coverage in fifty. Specific turn-times, scenario-desk SLAs, and comp models are published openly and citable.',
  },
  {
    question: 'How is broker compensation paid?',
    answer:
      'Compensation is paid on the broker-elected plan filed with the company — lender-paid (LPC) or borrower-paid (BPC), at the rate you have on file. Comp is disclosed on the lock confirmation, paid at funding, and reconciled monthly. Comp adjustments require a written plan change and are not negotiated file-by-file.',
  },
  {
    question: 'What states is Clout licensed to fund Non-QM in?',
    answer:
      'New York, New Jersey, Pennsylvania, Florida, Connecticut, and Texas under NMLS #65328. Brokers may submit files for properties located in any of these six states. Clout is not currently licensed for activity in California or other states outside the six listed.',
  },
  {
    question: 'How do I apply to become a Clout wholesale partner?',
    answer:
      'Email PowerUp@CLOUTwmb.com or call 844-477-3111. Submit a standard wholesale broker package (W-9, broker agreement, E&O certificate, NMLS license, AML policy, principal resumes) and complete a 30-minute onboarding call. Most brokers are approved and submitting their first file within 5–7 business days. Full application details live on the TPO Connect partner portal page.',
  },
];

// Service schema — the wholesale channel itself (distinct from TPO Connect Service @id)
const channelSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${pageUrl}#channel`,
  name: 'Clout Wholesale Non-QM Channel',
  alternateName: ['Clout Wholesale Partner Channel', 'Clout Broker Channel'],
  serviceType: 'Wholesale mortgage origination channel for licensed mortgage brokers',
  description:
    'Clout Wholesale Mortgage Bankers operates a wholesale Non-QM origination channel for licensed mortgage brokers placing DSCR, Bank Statement, 1099, Foreign National, Asset Qualifier, and other Non-QM loans in NY, NJ, PA, FL, CT, and TX. NMLS #65328. A division of Cliffco Mortgage Bankers (founded 1989).',
  provider: { '@id': `${SITE.url}#organization` },
  areaServed: STATES.map((s) => ({ '@type': 'State', name: s.name })),
  audience: {
    '@type': 'BusinessAudience',
    audienceType: 'Licensed mortgage brokers and brokerages (NMLS-registered)',
  },
  url: pageUrl,
  termsOfService: `${SITE.url}/tpo-connect/`,
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Non-QM loan programs available through the Clout wholesale channel',
    itemListElement: featuredProducts.map((p) => ({
      '@type': 'Offer',
      itemOffered: {
        '@type': 'LoanOrCredit',
        name: p.name,
        url: `${SITE.url}/loan-options/${p.slug}/`,
      },
    })),
  },
};
---

<Layout
  title="For Mortgage Brokers — Wholesale Non-QM Partner Channel"
  description="Place wholesale Non-QM files with Clout. 10 programs (DSCR, Bank Statement, 1099, Foreign National, Asset Qualifier), 15–25 day average close, named AE access, broker-elected comp. Licensed NY, NJ, PA, FL, CT, TX. NMLS #65328."
  canonical={pageUrl}
  breadcrumbs={breadcrumbs}
  extraSchema={[jsonLd(channelSchema), jsonLd(faqSchema(faqs))]}
>
  <section class="hero">
    <div class="container">
      <p class="eyebrow">For mortgage brokers · NMLS #{SITE.nmlsId}</p>
      <h1>Place Non-QM files with a wholesale lender that closes.</h1>
      <p class="answer-first lead">
        Clout is the wholesale Non-QM channel for licensed mortgage brokers across NY,
        NJ, PA, FL, CT, and TX. Ten programs through one submission point, 15–25 day
        average clear-to-close on DSCR and Bank Statement files, named account
        executives with a 4-business-hour response commitment, and broker-elected
        comp. A division of Cliffco Mortgage Bankers (founded 1989).
      </p>
      <div class="hero-cta">
        <a href="/tpo-connect/" class="cta-primary">Partner login</a>
        <a href="/tpo-connect/#apply" class="cta-secondary">Apply to partner</a>
      </div>
      <p class="reviewed-by">
        Reviewed by Clout Wholesale Operations · NMLS #{SITE.nmlsId} · Last updated <time datetime={lastUpdatedIso}>{lastUpdatedDisplay}</time>
      </p>
    </div>
  </section>

  <section class="band band-tldr">
    <div class="container">
      <div class="tldr">
        <h2>The channel at a glance</h2>
        <ul>
          <li><span class="label">Programs</span><span class="value">10 Non-QM</span></li>
          <li><span class="label">States</span><span class="value">NY · NJ · PA · FL · CT · TX</span></li>
          <li><span class="label">Loan amounts</span><span class="value">$100K – $5M</span></li>
          <li><span class="label">Min FICO (standard)</span><span class="value">620</span></li>
          <li><span class="label">Typical clear-to-close</span><span class="value">15–25 days (DSCR · Bank Statement)</span></li>
          <li><span class="label">Initial decision</span><span class="value">24–72 hours</span></li>
          <li><span class="label">Compensation</span><span class="value">Broker-elected LPC or BPC</span></li>
          <li><span class="label">Submission</span><span class="value">eDoc via TPO Connect</span></li>
        </ul>
      </div>
    </div>
  </section>

  <section class="band">
    <div class="container">
      <header class="section-head">
        <p class="eyebrow">Why Clout</p>
        <h2>Six reasons brokers place Non-QM files with us.</h2>
      </header>
      <div class="value-grid">
        {valueProps.map((v) => (
          <article class="value-card">
            <h3>{v.title}</h3>
            <p>{v.detail}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="band band-dark">
    <div class="container">
      <header class="section-head">
        <p class="eyebrow">Service standards</p>
        <h2>What Clout commits to in writing.</h2>
      </header>
      <div class="standards-table-wrap">
        <table class="standards-table" aria-label="Clout broker service standards">
          <thead>
            <tr>
              <th scope="col">Commitment</th>
              <th scope="col">Standard</th>
            </tr>
          </thead>
          <tbody>
            {serviceStandards.map(([k, v]) => (
              <tr>
                <th scope="row">{k}</th>
                <td>{v}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="standards-note">
        Standards are published expectations during normal business hours (Monday–Friday,
        8 AM – 6 PM ET) and assume clean files. Hard cutoffs and rate-lock-extension
        policies are documented inside TPO Connect.
      </p>
    </div>
  </section>

  <section class="band">
    <div class="container">
      <header class="section-head">
        <p class="eyebrow">Programs</p>
        <h2>What you can place through the Clout channel.</h2>
      </header>
      <div class="product-grid">
        {featuredProducts.map((p) => (
          <a href={`/loan-options/${p.slug}/`} class="product-card">
            <div class="product-card-head">
              <span class="product-tier">Tier {p.tier}</span>
              <h3>{p.shortName}</h3>
            </div>
            <p>{p.shortDescription}</p>
            <span class="product-link">Program details →</span>
          </a>
        ))}
      </div>
      <p class="tier4-note">
        Plus three narrow-use programs:
        {PRODUCTS.filter((p) => p.tier === 4).map((p, i, arr) => (
          <>
            <a href={`/loan-options/${p.slug}/`}>{p.shortName}</a>{i < arr.length - 1 && ', '}
          </>
        ))}.
      </p>
    </div>
  </section>

  <section class="band band-surface">
    <div class="container">
      <header class="section-head">
        <p class="eyebrow">States</p>
        <h2>Where you can place Clout Non-QM files.</h2>
      </header>
      <div class="state-grid">
        {STATES.map((s) => (
          <a href={`/locations/${s.slug}/`} class="state-card">
            <p class="state-abbr">{s.abbr}</p>
            <h3>{s.name}</h3>
            <p class="state-metros">{s.topMetros.slice(0, 4).join(' · ')}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="band">
    <div class="container">
      <header class="section-head">
        <p class="eyebrow">What's different</p>
        <h2>How Clout compares to other wholesale Non-QM lenders.</h2>
      </header>
      <div class="diff-grid">
        {differentiators.map((d) => (
          <article class="diff-card">
            <h3>{d.point}</h3>
            <p>{d.detail}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="band band-dark">
    <div class="container">
      <header class="section-head">
        <p class="eyebrow">Path to placement</p>
        <h2>Three steps from cold to closing.</h2>
      </header>
      <ol class="step-list">
        {placementSteps.map((s) => (
          <li class="step">
            <span class="step-n">{s.n}</span>
            <div>
              <h3>{s.title}</h3>
              <p>{s.body}</p>
            </div>
          </li>
        ))}
      </ol>
      <p class="step-detail">
        Full onboarding detail, the scenario desk, the AE directory, and the live
        rate-sheet refresh schedule live on the <a href="/tpo-connect/">TPO Connect partner portal page →</a>
      </p>
      <div class="step-cta">
        <a href="/tpo-connect/#apply" class="cta-primary">Apply to partner</a>
        <a href={`tel:${SITE.phone}`} class="cta-secondary">Call {SITE.phoneDisplay}</a>
      </div>
    </div>
  </section>

  <section class="band">
    <div class="container">
      <header class="section-head">
        <p class="eyebrow">Frequently asked</p>
        <h2>What brokers ask about partnering with Clout.</h2>
      </header>
      <div class="faq" itemscope itemtype="https://schema.org/FAQPage">
        {faqs.map((f) => (
          <details itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
            <summary itemprop="name">{f.question}</summary>
            <div itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
              <p itemprop="text">{f.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="band band-compliance">
    <div class="container">
      <p class="compliance-row">
        Clout Wholesale Mortgage Bankers is a division of Cliffco Mortgage Bankers.
        NMLS <a href={SITE.nmlsUrl} rel="noopener" target="_blank">#{SITE.nmlsId}</a>.
        Equal Housing Lender. The Clout wholesale channel is available to NMLS-registered
        mortgage brokers and brokerages only. Programs, rates, loan amounts, and turn-times
        are subject to change without notice and to underwriting approval. Page last
        updated <time datetime={lastUpdatedIso}>{lastUpdatedDisplay}</time>.
      </p>
    </div>
  </section>
</Layout>

<style>
  .container { max-width: 1180px; margin: 0 auto; padding: 0 1.5rem; }

  .hero {
    padding: 5rem 0 3.5rem;
    background:
      radial-gradient(900px 420px at 80% -10%, color-mix(in srgb, var(--color-brand-warmth) 14%, transparent) 0%, transparent 60%),
      linear-gradient(180deg, var(--color-paper) 0%, var(--color-surface) 100%);
  }
  .hero h1 {
    font-size: clamp(2rem, 4.6vw, 3.25rem);
    line-height: 1.08;
    margin: 0 0 1.25rem;
    max-width: 22ch;
  }
  .hero .lead { max-width: 64ch; margin: 0 0 1.75rem; }
  .hero-cta { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .hero .reviewed-by { margin: 1.5rem 0 0; }

  .band { padding: 4rem 0; }
  .band-tldr { padding-top: 0; margin-top: -1.5rem; position: relative; z-index: 1; }
  .band-surface { background: var(--color-surface); }
  .band-dark { background: var(--color-brand-deep); color: var(--color-paper); }
  .band-dark .eyebrow { color: var(--color-brand-bright); }
  .band-dark h2, .band-dark h3 { color: var(--color-paper); }
  .band-compliance { padding: 2rem 0 3.5rem; }

  .band-tldr .tldr { background: var(--color-paper); box-shadow: 0 12px 40px -24px rgba(0, 65, 70, 0.18); }
  .band-tldr .tldr ul {
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
    column-gap: 2.5rem;
  }
  @media (max-width: 720px) { .band-tldr .tldr ul { grid-template-columns: 1fr; } }

  .section-head { margin: 0 0 2.5rem; max-width: 56ch; }
  .section-head h2 { font-size: clamp(1.5rem, 3vw, 2.25rem); line-height: 1.2; margin: 0; }

  /* Value props */
  .value-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .value-card {
    padding: 1.75rem;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    background: var(--color-paper);
    transition: border-color 120ms ease, transform 120ms ease, box-shadow 120ms ease;
  }
  .value-card:hover {
    border-color: var(--color-brand);
    transform: translateY(-2px);
    box-shadow: 0 16px 32px -16px rgba(1, 128, 118, 0.18);
  }
  .value-card h3 { font-size: 1.0625rem; margin: 0 0 0.5rem; color: var(--color-brand-deep); }
  .value-card p { margin: 0; color: var(--color-ink-soft); font-size: var(--text-small); line-height: 1.65; }

  /* Standards table */
  .standards-table-wrap { overflow-x: auto; }
  .standards-table {
    width: 100%;
    border-collapse: collapse;
    color: var(--color-paper);
    font-size: var(--text-small);
  }
  .standards-table thead th {
    text-align: left;
    padding: 0.875rem 1rem;
    font-weight: 600;
    color: var(--color-brand-bright);
    font-size: var(--text-meta);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border-bottom: 1px solid color-mix(in srgb, var(--color-brand-bright) 30%, transparent);
  }
  .standards-table tbody th,
  .standards-table tbody td {
    padding: 1rem;
    border-bottom: 1px solid color-mix(in srgb, var(--color-paper) 12%, transparent);
    vertical-align: top;
  }
  .standards-table tbody th { font-weight: 600; text-align: left; width: 50%; }
  .standards-note {
    margin-top: 1rem;
    font-size: var(--text-meta);
    color: color-mix(in srgb, var(--color-paper) 70%, transparent);
    max-width: 72ch;
  }

  /* Product cards (matches /tpo-connect/) */
  .product-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .product-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.5rem;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    background: var(--color-paper);
    text-decoration: none;
    color: var(--color-ink);
    transition: border-color 120ms ease, transform 120ms ease, box-shadow 120ms ease;
  }
  .product-card:hover {
    border-color: var(--color-brand);
    transform: translateY(-2px);
    box-shadow: 0 16px 32px -16px rgba(1, 128, 118, 0.18);
  }
  .product-card-head { display: flex; align-items: baseline; gap: 0.75rem; }
  .product-tier {
    font-size: var(--text-micro);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-mid);
    font-weight: 600;
  }
  .product-card h3 { font-size: 1.125rem; margin: 0; }
  .product-card p { margin: 0; color: var(--color-ink-soft); font-size: var(--text-small); }
  .product-link { color: var(--color-brand-deep); font-weight: 600; margin-top: auto; font-size: var(--text-small); }
  .tier4-note { color: var(--color-mid); margin-top: 1.5rem; font-size: var(--text-small); }
  .tier4-note a { color: var(--color-ink-soft); }

  /* States grid */
  .state-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .state-card {
    display: block;
    padding: 1.5rem;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    background: var(--color-paper);
    color: var(--color-ink);
    text-decoration: none;
    transition: border-color 120ms ease, transform 120ms ease;
  }
  .state-card:hover {
    border-color: var(--color-brand);
    transform: translateY(-2px);
  }
  .state-abbr {
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-brand-warmth);
    margin: 0 0 0.5rem;
    font-weight: 700;
  }
  .state-card h3 { font-size: 1.375rem; margin: 0 0 0.5rem; color: var(--color-brand-deep); }
  .state-metros { color: var(--color-ink-soft); font-size: var(--text-small); margin: 0; }

  /* Differentiators */
  .diff-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
  .diff-card {
    padding: 1.75rem;
    border: 1px solid var(--color-line);
    border-left: 3px solid var(--color-brand-warmth);
    border-radius: var(--radius-lg);
    background: var(--color-paper);
  }
  .diff-card h3 { margin: 0 0 0.5rem; font-size: 1.125rem; color: var(--color-brand-deep); }
  .diff-card p { margin: 0; color: var(--color-ink-soft); font-size: var(--text-small); line-height: 1.65; }

  /* Placement steps */
  .step-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .step {
    background: color-mix(in srgb, var(--color-paper) 6%, transparent);
