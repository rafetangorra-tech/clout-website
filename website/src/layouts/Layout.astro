---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import {
  organizationSchema,
  localBusinessSchema,
  breadcrumbSchema,
  jsonLd,
} from '../data/schema';
import { SITE } from '../data/site';

type Breadcrumb = { name: string; url: string };

interface Props {
  title: string;
  description: string;
  /** Will be rendered as <link rel="canonical" />. Should be absolute. */
  canonical?: string;
  /** Path segment for OG image; defaults to brand logo. */
  ogImage?: string;
  /** Breadcrumb trail starting at homepage. */
  breadcrumbs?: Breadcrumb[];
  /** Additional JSON-LD blocks (already stringified). */
  extraSchema?: string[];
  /** Optional noindex for search/utility pages. */
  noindex?: boolean;
}

const {
  title,
  description,
  canonical = Astro.url.href,
  ogImage = '/brand/logo-primary.svg',
  breadcrumbs,
  extraSchema = [],
  noindex = false,
} = Astro.props;

const fullTitle = title.includes(SITE.name) ? title : `${title} · ${SITE.name}`;

const schemaBlocks: string[] = [
  jsonLd(organizationSchema()),
  jsonLd(localBusinessSchema()),
  ...(breadcrumbs ? [jsonLd(breadcrumbSchema(breadcrumbs))] : []),
  ...extraSchema,
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light" />
    <meta name="theme-color" content="#018076" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,follow" />}
    <link rel="canonical" href={canonical} />

    {/* Open Graph + Twitter */}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={SITE.name} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {/* Icon */}
    <link rel="icon" type="image/svg+xml" href="/brand/icon-primary.svg" />

    {/* JSON-LD schema */}
    {schemaBlocks.map((block) => (
      <script type="application/ld+json" set:html={block} />
    ))}
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to main content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
